# VXIS Environment Variables
# Copy to .env and fill in your keys

# Shodan API Key (optional, for passive recon)
# VXIS_SHODAN_API_KEY=your_key_here

# GitHub Token (for trufflehog org scanning)
# VXIS_GITHUB_TOKEN=ghp_your_token_here

# Anthropic API Key (for AI-generated report summaries)
# VXIS_ANTHROPIC_API_KEY=sk-ant-your_key_here
